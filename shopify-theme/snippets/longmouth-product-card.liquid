{% assign hover_media = product.metafields.custom.hover_image.value %}
{% assign size_chart_value = product.metafields.custom.size_chart.value %}
{% assign thumbnail_width = 250 %}
{% if product.featured_image %}
  {% assign featured_width = product.featured_image.width | at_most: thumbnail_width %}
  {% assign featured_height = product.featured_image.height | times: featured_width | divided_by: product.featured_image.width %}
{% endif %}
{% if hover_media != blank %}
  {% assign hover_width = hover_media.width | at_most: thumbnail_width %}
  {% assign hover_height = hover_media.height | times: hover_width | divided_by: hover_media.width %}
{% elsif product.images.size > 1 %}
  {% assign hover_width = product.images[1].width | at_most: thumbnail_width %}
  {% assign hover_height = product.images[1].height | times: hover_width | divided_by: product.images[1].width %}
{% endif %}

<div class="s__product-item product-wrapper">
  <div
    class="product-list__item"
    data-id="{{ product.id }}"
    data-product-handle="{{ product.handle }}"
    data-product-tags="{{ product.tags | join: ',' | downcase }}"
    {% unless size_chart_value == blank %}data-size-chart-url="{{ size_chart_value.url | default: size_chart_value }}"{% endunless %}
    role="button"
    tabindex="0"
    aria-label="Open {{ product.title | escape }}"
  >
    {% if product.featured_image %}
      <img
        class="product-grid__mobile-thumbnail"
        loading="eager"
        decoding="async"
        src="{{ product.featured_image | image_url: width: featured_width }}"
        width="{{ featured_width }}"
        height="{{ featured_height }}"
        alt="{{ product.title | escape }}"
      >
    {% endif %}

    <div class="product-list__name">{{ product.title }}</div>

    {% if hover_media != blank %}
      <img
        class="product-list__hover-image"
        loading="eager"
        decoding="async"
        src="{{ hover_media | image_url: width: hover_width }}"
        width="{{ hover_width }}"
        height="{{ hover_height }}"
        alt="{{ product.title | escape }} hover"
      >
    {% elsif product.images.size > 1 %}
      <img
        class="product-list__hover-image"
        loading="eager"
        decoding="async"
        src="{{ product.images[1] | image_url: width: hover_width }}"
        width="{{ hover_width }}"
        height="{{ hover_height }}"
        alt="{{ product.title | escape }} hover"
      >
    {% endif %}

    <div class="product-list__price is-hidden">{{ product.price | money_without_currency }}</div>
    <div class="price-wrap product-grid">
      {% assign selected_variant = product.selected_or_first_available_variant %}
      {% if selected_variant and selected_variant.available %}
        {% if selected_variant.compare_at_price > selected_variant.price %}
          <span class="price_compare-at-price">{{ selected_variant.compare_at_price | money }}</span>
        {% endif %}
        <span class="price_regular-price">{{ selected_variant.price | money }}</span>
      {% else %}
        <span class="price_out-of-stock">sold out</span>
      {% endif %}
    </div>
  </div>
</div>
