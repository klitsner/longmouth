<div class="footer__wrap">
  <div class="menu__wrap" data-longmouth-menu>
    <button id="shop__button" type="button" class="menu__item outline-lookbook" data-open-view="shop">
      <div class="menu__item-text">{{ menu_label_shop | default: 'shop' }}</div>
      <div class="menu__item-text-hvr">{{ menu_label_shop | default: 'shop' }}</div>
    </button>

    <button type="button" class="menu__item outline-waitlist" data-open-modal="waitlist-modal">
      <div class="menu__item-text">{{ menu_label_waitlist | default: 'maillist' }}</div>
      <div class="menu__item-text-hvr">{{ menu_label_waitlist | default: 'maillist' }}</div>
    </button>

    <button type="button" class="menu__item outline-contact" data-open-modal="contact-modal">
      <div class="menu__item-text">{{ menu_label_contact | default: 'contact' }}</div>
      <div class="menu__item-text-hvr">{{ menu_label_contact | default: 'contact' }}</div>
    </button>

    <button id="otherstuff__button" type="button" class="menu__item outline-top-side" data-open-view="policy">
      <div class="menu__item-text">{{ menu_label_policy | default: 'other stuff' }}</div>
      <div class="menu__item-text-hvr">{{ menu_label_policy | default: 'other stuff' }}</div>
    </button>
  </div>

  <div class="menu-back__wrap" hidden>
    <button id="home__button-footer" type="button" class="menu__item outline-top-side" data-open-view="home">
      <div class="menu__item-text">{{ menu_label_back_home | default: 'back to world' }}</div>
      <div class="menu__item-text-hvr">{{ menu_label_back_home | default: 'back to world' }}</div>
    </button>
  </div>

