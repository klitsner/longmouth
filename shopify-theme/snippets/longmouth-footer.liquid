          <path d="M10 16L2 6h16l-8 10z" fill="#ff4a4a"/>
        </svg>
        <h1 class="sol-ring-up down">-5%</h1>
        <div class="stock-text">sol ring</div>
      </div>
      <div class="stock _2">
        <svg class="image" viewBox="0 0 20 20" role="presentation" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
          <path d="M10 4l8 10H2L10 4z" fill="#75e768"/>
        </svg>
        <h1 class="sol-ring-up">+1000%</h1>
        <div class="stock-text">auratog</div>
      </div>
