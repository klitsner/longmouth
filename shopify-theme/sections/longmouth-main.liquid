{% render 'longmouth-main', section: section %}

{% schema %}
{
  "name": "Main",
  "settings": [
    {
      "type": "select",
      "id": "menu_cover_mode",
      "label": "Loader overlay visibility",
      "default": "hide_on_load",
      "options": [
        { "value": "hide_on_load", "label": "Hide on load" },
        { "value": "hide", "label": "Hide" },
        { "value": "show", "label": "Show" }
      ]
    },
    {
      "type": "image_picker",
      "id": "menu_cover_image",
      "label": "Loader overlay image"
    },
    {
      "type": "text",
      "id": "menu_cover_alt",
      "label": "Loader overlay alt text",
      "default": "Loading"
    },
    {
      "type": "checkbox",
      "id": "card_draw_enabled",
      "label": "Enable card draw module",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "hero_logo_enabled",
      "label": "Show hero logo",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "hero_logo_image",
      "label": "Hero logo image"
    },
    {
      "type": "text",
      "id": "hero_logo_alt",
      "label": "Hero logo alt text",
      "default": "Longmouth logo"
    }
  ],
  "blocks": [
    {
      "type": "gallery_media",
      "name": "Gallery media",
      "settings": [
        {
          "type": "select",
          "id": "media_type",
          "label": "Media type",
          "default": "image",
          "options": [
            { "value": "image", "label": "Image" },
            { "value": "video", "label": "Video" }
          ]
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "video",
          "id": "video",
          "label": "Video"
        },
        {
          "type": "text",
          "id": "alt",
          "label": "Image alt text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Main",
      "blocks": [
        {
          "type": "gallery_media"
        }
      ]
    }
  ]
}
{% endschema %}